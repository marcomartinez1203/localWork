{
  "name": "localwork",
  "version": "1.0.0",
  "description": "LocalWork Application",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./frontend/assets/css/styles.css -o ./frontend/assets/css/tailwind.css --minify",
    "build:backend": "cd backend && npm install && npm run build",
    "build": "npm run build:backend && npm run build:css",
    "dev:css": "npx @tailwindcss/cli -i ./frontend/assets/css/styles.css -o ./frontend/assets/css/tailwind.css --watch"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
}
